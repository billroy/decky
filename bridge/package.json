{
  "name": "decky-bridge",
  "version": "0.1.0",
  "description": "Decky bridge server — receives Claude Code hooks, manages state, emits events via Socket.io",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "DECKY_HOME=.decky-test vitest run --maxWorkers=1 src/__tests__",
    "test:watch": "DECKY_HOME=.decky-test vitest src/__tests__"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
