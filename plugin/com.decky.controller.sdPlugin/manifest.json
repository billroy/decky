{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.decky.controller",
  "Name": "Decky",
  "Author": "billroy",
  "Description": "StreamDeck controller for Claude Code — approve, deny, and monitor tool use.",
  "CodePath": "bin/plugin.js",
  "Icon": "imgs/plugin/icon",
  "Version": "0.1.0.0",
  "SDKVersion": 2,
  "OS": [
    { "Platform": "mac", "MinimumVersion": "13" }
  ],
  "Software": { "MinimumVersion": "6.6" },
  "Nodejs": { "Version": "20" },
  "Actions": [
    {
      "UUID": "com.decky.controller.status",
      "Name": "Bridge Status",
      "Icon": "imgs/actions/status/icon",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "imgs/actions/status/key", "Title": "Decky" }
      ]
    },
    {
      "UUID": "com.decky.controller.approve",
      "Name": "Approve",
      "Icon": "imgs/actions/approve/icon",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "imgs/actions/approve/key", "Title": "Approve" }
      ]
    },
    {
      "UUID": "com.decky.controller.deny",
      "Name": "Deny",
      "Icon": "imgs/actions/deny/icon",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "imgs/actions/deny/key", "Title": "Deny" }
      ]
    },
    {
      "UUID": "com.decky.controller.cancel",
      "Name": "Cancel",
      "Icon": "imgs/actions/cancel/icon",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "imgs/actions/cancel/key", "Title": "Cancel" }
      ]
    },
    {
      "UUID": "com.decky.controller.slot",
      "Name": "Decky Slot",
      "Tooltip": "Dynamic button that changes based on Claude Code state. Place multiple for full layout.",
      "Icon": "imgs/actions/slot/icon",
      "Controllers": ["Keypad"],
      "PropertyInspectorPath": "ui/property-inspector-v2.html",
      "States": [
        { "Image": "imgs/actions/slot/key", "Title": "Slot" }
      ]
    }
  ]
}
